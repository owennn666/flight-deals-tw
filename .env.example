# 複製成 .env 並填入。程式用 os.getenv 讀取（可搭配 direnv / python-dotenv）。

# ── 資料源（免費）──────────────────────────────
# Travelpayouts / Aviasales：免費註冊拿 token，是目前最適合的免費機票價格來源。
# 申請：travelpayouts.com 註冊 → Profile → API token。
TRAVELPAYOUTS_TOKEN=
# 聯盟 marker（選填）：填了之後訂票連結就是你的聯盟連結，可抽佣變現。
TRAVELPAYOUTS_MARKER=

# ── 推播 ───────────────────────────────────────
# LINE Messaging API 頻道 access token（台灣社群推播）
LINE_CHANNEL_ACCESS_TOKEN=

# ── 已淘汰，勿用於新專案 ────────────────────────
# Amadeus Self-Service 2026/7/17 停用（金鑰會失效），僅保留骨架供參考。
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
